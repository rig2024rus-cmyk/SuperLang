# Тест stratified negation с copy-правилами
# Критический баг v1.1.1 — copy-правило получало stratum 0
# и отрабатывало до того, как impl-правило что-то вывело

relation task(id)
relation depends(src, dst)
relation finished(id)

input {
    task(T1)
    task(T2)
    task(T3)
    depends(T3, T2)
    depends(T2, T1)
    finished(T1)
}

# blocked(X) = X зависит от чего-то, что не finished
derive blocked(id) from
    depends(id, dep),
    not finished(dep)

# ready(X) = X не blocked
derive ready(id) from
    task(id),
    not blocked(id)

query blocked(!ID)
query ready(!ID)
