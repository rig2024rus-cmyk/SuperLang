 void saturate(Config *c, const ClosureIR *closure) {
     if (!c || !closure) return;
-    
-    int changed = 1;
-    int max_iterations = 100;
-    int iteration = 0;
-    
-    while (changed && iteration < max_iterations) {
-        changed = 0;
-        for (Rule *r = closure->rules; r; r = r->next) {
-            int added = apply_rule(c, r);
-            if (added > 0) changed = 1;
+
+    /* Rules must be applied in non-decreasing stratum order, running each
+     * stratum to its own fixpoint before advancing — that is the entire
+     * point of stratification: a negated predicate must be fully computed
+     * before any rule that negates it runs, or a rule can permanently commit
+     * a fact based on an incomplete view of what it negates (this engine
+     * has no retraction, so such a fact can never later be corrected).
+     * r->stratum is precomputed by graph_compute_strata() from the same SCC
+     * condensation that graph_validate_semantics() uses to reject
+     * non-stratifiable programs, so this loop can trust it directly instead
+     * of re-deriving stratum order here. */
+    int max_stratum = 0;
+    for (Rule *r = closure->rules; r; r = r->next) {
+        if (r->stratum > max_stratum) max_stratum = r->stratum;
+    }
+
+    int max_iterations = 10000; /* fixpoint safety cap per stratum */
+
+    for (int s = 0; s <= max_stratum; s++) {
+        int changed = 1;
+        int iteration = 0;
+        while (changed && iteration < max_iterations) {
+            changed = 0;
+            for (Rule *r = closure->rules; r; r = r->next) {
+                if (r->stratum != s) continue;
+                int added = apply_rule(c, r);
+                if (added > 0) changed = 1;
+            }
+            iteration++;
         }
-        iteration++;
     }
 }
