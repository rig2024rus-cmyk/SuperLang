relation parent(child, parent)

input {
    parent(alice, bob)
    parent(bob, charlie)
    parent(alice, david)
    parent(eve, eve)
}

# 1. Ground query (True)
query parent(alice, bob)       # → TRUE

# 2. Ground query (False)
query parent(charlie, alice)   # → FALSE

# 3. Single variable with ! prefix
query parent(alice, !X)        # → [david, bob]

# 4. Unification test (!X must equal !Y)
query parent(!X, !X)           # → [eve]

# 5. Multiple variables
query parent(!X, !Y)           # → [(eve, eve), (alice, david), (bob, charlie), (alice, bob)]

# 6. No results
query parent(charlie, !X)      # → []

# 7. Complex variable names
query parent(!Child, !Parent)  # Same as above
