# ============================================================================
# Тест оператора % и многострочных комментариев
# ============================================================================

[--
Это многострочный комментарий.
Может занимать несколько строк.
Используется для документации больших блоков кода.
--]

relation number(x)

[-- Задаём числа от 0 до 30 для тестирования модуля --]
input {
    number(0)
    number(1)
    number(2)
    number(3)
    number(4)
    number(5)
    number(10)
    number(15)
    number(20)
    number(25)
    number(30)
}

# Вычисляем остаток от деления на 7
derive mod7(x, result) from
    number(x),
    result = x % 7

# Проверяем, какие числа делятся на 5 без остатка
derive divisible_by_5(x) from
    number(x),
    result = x % 5,
    result == 0

# Циклическая функция (как лунный день!)
derive cyclic(x, result) from
    number(x),
    result = x % 30

query mod7(!X, !R)
query divisible_by_5(!X)
query cyclic(!X, !R)
